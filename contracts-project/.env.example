# RPC endpoint for Sepolia testnet (e.g. from Alchemy or Infura)
SEPOLIA_RPC_URL=

# Private key of the ADMIN wallet used to deploy the contract (deployer == admin, immutable).
# NEVER commit your real .env file. Use a dedicated test wallet, not one holding real funds.
ADMIN_PRIVATE_KEY=

# Username shown for the admin account
ADMIN_USERNAME=admin

# Temporary/initial admin password (used only by the deploy script to compute the on-chain hash,
# never stored in plaintext anywhere on-chain)
ADMIN_INITIAL_PASSWORD=changeme123

# Etherscan API key, used to verify the deployed contract source on sepolia.etherscan.io
ETHERSCAN_API_KEY=
